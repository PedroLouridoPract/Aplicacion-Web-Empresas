# ============================================================
# API REST - App Web Empresas (Backend)
# Usar con la extensión REST Client de VS Code/Cursor.
# Click en "Send Request" sobre cada petición o Ctrl+Alt+R
# ============================================================

@baseUrl = http://localhost:3000
# Después de hacer login, copia aquí el token:
@token = 
# Opcional: rellena tras crear un proyecto, tarea, usuario o comentario:
@projectId = 
@taskId = 
@userId =
@commentId =


# ========== SIN AUTENTICACIÓN ==========

### Health check
GET {{baseUrl}}/health


# ========== AUTH ==========

### Registrar empresa + primer usuario (admin)
POST {{baseUrl}}/auth/register-company
Content-Type: application/json

{
  "companyName": "Empresa Demo",
  "adminName": "Admin Demo",
  "adminEmail": "admin@demo.com",
  "adminPassword": "password123"
}


### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@demo.com",
  "password": "password123"
}


### Obtener mi perfil (requiere token)
GET {{baseUrl}}/auth/me
Authorization: Bearer {{token}}


# ========== PROYECTOS (requieren token) ==========

### Listar proyectos de la empresa
GET {{baseUrl}}/projects
Authorization: Bearer {{token}}


### Crear proyecto (solo ADMIN)
POST {{baseUrl}}/projects
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Proyecto Alpha",
  "description": "Descripción del proyecto de prueba",
  "startDate": "2026-03-01",
  "endDate": "2026-06-30",
  "status": "ACTIVE"
}


### Obtener un proyecto por ID
GET {{baseUrl}}/projects/{{projectId}}
Authorization: Bearer {{token}}


### Actualizar proyecto (ADMIN o MEMBER)
PATCH {{baseUrl}}/projects/{{projectId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Proyecto Alpha (actualizado)",
  "status": "ACTIVE"
}


### Eliminar proyecto (solo ADMIN)
DELETE {{baseUrl}}/projects/{{projectId}}
Authorization: Bearer {{token}}


### Listar tareas de un proyecto
GET {{baseUrl}}/projects/{{projectId}}/tasks
Authorization: Bearer {{token}}


### Vista ejecutiva de un proyecto (overdue, this_week, next_week)
GET {{baseUrl}}/projects/{{projectId}}/executive
Authorization: Bearer {{token}}


# ========== USUARIOS (requieren token; crear/editar solo ADMIN) ==========

### Listar usuarios de la empresa
GET {{baseUrl}}/users
Authorization: Bearer {{token}}

### Crear usuario (solo ADMIN)
POST {{baseUrl}}/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Nuevo Miembro",
  "email": "miembro@empresa.com",
  "password": "password123",
  "role": "MEMBER"
}

### Crear usuario invitado (solo ADMIN)
POST {{baseUrl}}/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Invitado Demo",
  "email": "invitado@empresa.com",
  "password": "password123",
  "role": "GUEST"
}

### Actualizar usuario (solo ADMIN, ej. cambiar rol)
PATCH {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "role": "ADMIN"
}


# ========== TAREAS (requieren token; GUEST solo lectura) ==========

### Listar todas las tareas de la empresa (filtros opcionales: ?projectId=X&assigneeId=X&status=X)
GET {{baseUrl}}/tasks
Authorization: Bearer {{token}}

### Listar tareas filtradas por proyecto
GET {{baseUrl}}/tasks?projectId={{projectId}}
Authorization: Bearer {{token}}

### Listar tareas filtradas por estado
GET {{baseUrl}}/tasks?status=IN_PROGRESS
Authorization: Bearer {{token}}

### Mis tareas (asignadas al usuario actual)
GET {{baseUrl}}/tasks/mine
Authorization: Bearer {{token}}

### Obtener una tarea
GET {{baseUrl}}/tasks/{{taskId}}
Authorization: Bearer {{token}}

### Crear tarea (ADMIN o MEMBER)
POST {{baseUrl}}/tasks
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "projectId": "{{projectId}}",
  "title": "Nueva tarea",
  "description": "Descripción opcional",
  "assigneeId": null,
  "dueDate": "2026-03-15",
  "priority": "MEDIUM",
  "status": "BACKLOG"
}

### Actualizar tarea (ADMIN o asignado)
PATCH {{baseUrl}}/tasks/{{taskId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Título actualizado",
  "progress": 50,
  "status": "IN_PROGRESS"
}

### Mover tarea (cambiar estado y orden - ADMIN o asignado)
# status: BACKLOG | IN_PROGRESS | REVIEW | DONE (o minúsculas)
PATCH {{baseUrl}}/tasks/{{taskId}}/move
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "IN_PROGRESS",
  "orderIndex": 0
}

### Eliminar tarea (ADMIN o asignado)
DELETE {{baseUrl}}/tasks/{{taskId}}
Authorization: Bearer {{token}}


# ========== COMENTARIOS (requieren token; GUEST solo lectura) ==========

### Listar comentarios de una tarea
GET {{baseUrl}}/comments/by-task/{{taskId}}
Authorization: Bearer {{token}}


### Crear comentario (ADMIN o MEMBER)
POST {{baseUrl}}/comments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "taskId": "{{taskId}}",
  "body": "Este es un comentario de prueba."
}

### Eliminar comentario (ADMIN o autor del comentario)
DELETE {{baseUrl}}/comments/{{commentId}}
Authorization: Bearer {{token}}


# ========== DASHBOARD (requieren token; solo ADMIN) ==========

### Resumen / KPIs (toda la empresa)
GET {{baseUrl}}/dashboard/summary
Authorization: Bearer {{token}}


### Resumen por proyecto (opcional query projectId)
GET {{baseUrl}}/dashboard/summary?projectId={{projectId}}
Authorization: Bearer {{token}}


### Productividad por usuario (últimos 14 días por defecto)
GET {{baseUrl}}/dashboard/productivity
Authorization: Bearer {{token}}


### Productividad por proyecto (personalizado: últimos 7 días)
GET {{baseUrl}}/dashboard/productivity?projectId={{projectId}}&days=7
Authorization: Bearer {{token}}
