generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
  GUEST
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  projects  Project[]
  tasks     Task[]
  comments  Comment[]
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  email        String?  @unique
  passwordHash String   @default("")
  phone        String?
  avatarUrl    String?
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())

  assignedTasks   Task[]           @relation("TaskAssignee")
  lockedTasks     Task[]           @relation("TaskLocker")
  comments        Comment[]
  notifications   Notification[]
  attachments     Attachment[]
}

model Project {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  leadName    String?
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  tasks          Task[]
  kanbanColumns  KanbanColumn[]

  @@index([companyId])
}

model Task {
  id           String     @id @default(cuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id])

  title        String
  summary      String?
  description  String?
  assigneeId   String?
  assignee     User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])

  creatorName  String?
  reporterName String?

  dueDate      DateTime?
  resolvedAt   DateTime?
  priority     Priority   @default(MEDIUM)
  status       TaskStatus @default(BACKLOG)
  customStatus String?
  progress     Int        @default(0)
  orderIndex   Int        @default(1000)

  lockedById   String?
  lockedBy     User?      @relation("TaskLocker", fields: [lockedById], references: [id])
  lockedAt     DateTime?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  comments     Comment[]
  attachments  Attachment[]

  @@index([companyId, projectId, status, orderIndex])
  @@index([companyId, assigneeId, dueDate])
}

model Attachment {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  originalName String
  mimeType     String
  size         Int
  data         Bytes
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([taskId])
}

model Comment {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])

  taskId     String
  task       Task     @relation(fields: [taskId], references: [id])

  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])
  authorName String?

  body        String
  attachments String?
  reactions   String?

  parentId    String?
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")

  createdAt   DateTime @default(now())

  @@index([companyId, taskId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  taskId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

model KanbanColumn {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key       String
  label     String
  position  Int      @default(0)
  isBase    Boolean  @default(false)
  color     String?
  createdAt DateTime @default(now())

  @@unique([projectId, key])
  @@index([projectId, position])
}
